# ── Social Spark Studio — environment template ─────────────────────
# Copy to .env and fill in your real values. Never commit .env.

# Google AI / Gemini
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud project (required for Imagen, Speech-to-Text, Text-to-Speech)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=keys/your-service-account.json

# Image generation
IMAGEN_MODEL=imagen-4.0-generate-001
GCS_BUCKET_NAME=your-gcs-bucket-name

# Voice Conversation Studio
SPEECH_TO_TEXT_MODEL=chirp_3
TTS_VOICE_NAME=en-US-Chirp3-HD-Aoede
TTS_LANGUAGE_CODE=en-US
VOICE_AGENT_MODEL=gemini-2.5-flash
VOICE_STATE_PATH=data/voice_conversation_state.json
MESSAGE_DNA_OUTPUT_PATH=data/message_dna_output.json

# Demo login gate (optional — if unset, login is open for local dev)
DEMO_PASSWORD=your-demo-password-here

# Set to true when deploying to Cloud Run
# Set to false for local development (uses local JSON files)
USE_FIRESTORE=false
